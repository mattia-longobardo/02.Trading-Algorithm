OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_HEAVY=gpt-5.4
OPENAI_MODEL_MID=gpt-5.4-mini
OPENAI_MODEL_LIGHT=gpt-5.4-nano
OPENAI_REASONING_EFFORT=medium
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
MAX_OPEN_TRADES_STOCK=3
MAX_OPEN_TRADES_CRYPTO=3
WEEKLY_UNIVERSE_STOCKS=5
WEEKLY_UNIVERSE_CRYPTO=5
CURRENCY=EUR
CRYPTO_ENTRY_LIMIT_COLLAR_BPS=15
CRYPTO_ENTRY_MAX_CHASE_BPS=40
CRYPTO_PENDING_REPRICE_MINUTES=2
CRYPTO_PENDING_CANCEL_MINUTES=12
LOG_LEVEL=INFO
LOG_FILE=logs/trading_bot.log
UNIVERSE_LOG_FILE=logs/universe_candidates.log
DB_MARKET_DATA=data/market_data.sqlite
DB_TRADES=data/trades.sqlite
LOCK_FILE=run/trading_scheduler.lock
# Origini consentite per il browser quando il frontend chiama questo backend.
# Lista separata da virgole; usare "*" per consentire qualunque origine (sconsigliato).
CORS_ALLOWED_ORIGINS=http://trading.local
