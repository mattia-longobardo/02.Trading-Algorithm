OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_HEAVY=gpt-5.4
OPENAI_MODEL_MID=gpt-5.4-mini
OPENAI_MODEL_LIGHT=gpt-5.4-nano
OPENAI_REASONING_EFFORT=medium
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
# Currency in which Alpaca reports balances, fills and PnL. Alpaca paper
# trading is always USD; live US-equities accounts are also USD. The bot
# stores trade values in this currency natively and converts to CURRENCY
# (below) at the API edge for display. ACCOUNT_CURRENCY is accepted as a
# legacy alias.
ALPACA_ACCOUNT_CURRENCY=USD
# Per-order notional cap enforced by Alpaca (error 40310000 above this).
# When the strategy's per-trade allocation exceeds this, the order is
# shrunk to the cap so the broker accepts it instead of rejecting the
# trade. Default 200000 matches Alpaca's documented limit at the time
# of writing — adjust if your account has a different ceiling.
ALPACA_MAX_NOTIONAL_PER_ORDER=200000

# --- Binance (optional) ---------------------------------------------------
# Leave empty to disable Binance entirely. When the API key and either a
# secret OR a private-key file are configured, the bot starts the Binance
# module side by side with Alpaca and the frontend exposes the
# corresponding tabs (universe, prompts, settings).
BINANCE_API_KEY=
# HMAC secret (classic Binance API key). Leave empty if you use the
# Ed25519/RSA "SSH-style" API key — set BINANCE_PRIVATE_KEY_PATH instead.
BINANCE_SECRET_KEY=
# Path to an Ed25519 or RSA private-key PEM file. When set, the client
# signs requests with this key and BINANCE_SECRET_KEY can be left blank.
# In Docker the file must be mounted into the container; see
# docker-compose.yml for the default ~/.ssh:/home/mattia/.ssh bind mount.
BINANCE_PRIVATE_KEY_PATH=/home/mattia/.ssh/binance_public.pem
# Optional passphrase if the PEM file is password-encrypted.
BINANCE_PRIVATE_KEY_PASSWORD=
BINANCE_BASE_URL=https://api.binance.com
# Quote currency for Binance pairs (USDT / BUSD / USDC / EUR …).
BINANCE_QUOTE_CURRENCY=USDT

MAX_OPEN_TRADES_STOCK=3
MAX_OPEN_TRADES_CRYPTO=3
MAX_OPEN_TRADES_BINANCE=3
WEEKLY_UNIVERSE_STOCKS=5
WEEKLY_UNIVERSE_CRYPTO=5
WEEKLY_UNIVERSE_BINANCE=5
# Display currency in the UI (KPIs, equity curve, allocation). Alpaca
# values are converted from ALPACA_ACCOUNT_CURRENCY and Binance values
# from BINANCE_QUOTE_CURRENCY before being summed and shown here.
CURRENCY=EUR
RISK_TOLERANCE=5
STRATEGY_HORIZON_DAYS_MIN=90
STRATEGY_HORIZON_DAYS_MAX=120
CRYPTO_ENTRY_LIMIT_COLLAR_BPS=15
CRYPTO_ENTRY_MAX_CHASE_BPS=40
CRYPTO_PENDING_REPRICE_MINUTES=2
CRYPTO_PENDING_CANCEL_MINUTES=12
# Binance-specific tuning (defaults to the same crypto values when empty).
BINANCE_ENTRY_LIMIT_COLLAR_BPS=15
BINANCE_ENTRY_MAX_CHASE_BPS=40
BINANCE_PENDING_REPRICE_MINUTES=2
BINANCE_PENDING_CANCEL_MINUTES=12
# Minimum profit cushion (percent of entry_price) that the trailing TP must
# guarantee. The bot rejects GPT signals whose
#   activation_pct - (distance / entry_price * 100)
# falls below this value, and floors the runtime trigger at
#   entry_price * (1 + buffer/100)
# so a trailing TP can never close the trade below entry. Default 0.5 covers
# roughly 2x crypto round-trip fees plus typical slippage on liquid pairs.
TRAILING_TP_MIN_PROFIT_BUFFER_PCT=0.5
LOG_LEVEL=INFO
LOG_PROFILE=PRODUCTION
LOG_FILE=logs/trading_bot.log
UNIVERSE_LOG_FILE=logs/universe_candidates.log
DB_MARKET_DATA=data/market_data.sqlite
DB_TRADES=data/trades.sqlite
DB_APP=data/app.sqlite
LOCK_FILE=run/trading_scheduler.lock

# --- Web app authentication ----------------------------------------------
# Used only on first boot to seed the initial admin user. Once the row
# exists, these env values are no longer consulted; rotate the password
# from the Settings UI or via a manual DB reset.
ADMIN_USERNAME=mattia
ADMIN_PASSWORD=21Antarte21
ADMIN_DISPLAY_NAME=Administrator

# When the app is served over HTTPS in production, set this to true so the
# session cookie is marked Secure. Behind plain HTTP (dev / Traefik on
# trading.local) leave it false.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# --- CORS ------------------------------------------------------------------
# With the recommended server-side proxy pattern (frontend Route Handlers),
# the backend never receives cross-origin requests so this can stay empty.
# Set it only if you re-expose `api.trading.local` directly to the browser.
CORS_ALLOWED_ORIGINS=
