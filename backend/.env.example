OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_HEAVY=gpt-5.4
OPENAI_MODEL_MID=gpt-5.4-mini
OPENAI_MODEL_LIGHT=gpt-5.4-nano
OPENAI_REASONING_EFFORT=medium

# --- eToro broker ----------------------------------------------------------
# Public API key (identifies the application) and User key (identifies your
# eToro account). Both required. Get them from the eToro API portal.
ETORO_API_KEY=your_etoro_api_key
ETORO_USER_KEY=your_etoro_user_key
# "demo" (eToro paper account, default) or "real" (live money).
ETORO_ACCOUNT_TYPE=demo
# Always 1 for unleveraged real-asset positions.
ETORO_DEFAULT_LEVERAGE=1
# eToro's per-position minimum investment in USD.
ETORO_MIN_TRADE_AMOUNT=50

MAX_OPEN_TRADES_STOCK=3
MAX_OPEN_TRADES_CRYPTO=3
WEEKLY_UNIVERSE_STOCKS=5
WEEKLY_UNIVERSE_CRYPTO=5
# Display currency in the UI (KPIs, equity curve, allocation). Values are
# converted from ALPACA_ACCOUNT_CURRENCY before being summed and shown here.
CURRENCY=EUR
RISK_TOLERANCE=5
STRATEGY_HORIZON_DAYS_MIN=90
STRATEGY_HORIZON_DAYS_MAX=120
CRYPTO_ENTRY_LIMIT_COLLAR_BPS=15
CRYPTO_ENTRY_MAX_CHASE_BPS=40
CRYPTO_PENDING_REPRICE_MINUTES=2
CRYPTO_PENDING_CANCEL_MINUTES=12
# Minimum profit cushion (percent of entry_price) that the trailing TP must
# guarantee. The bot rejects GPT signals whose
#   activation_pct - (distance / entry_price * 100)
# falls below this value, and floors the runtime trigger at
#   entry_price * (1 + buffer/100)
# so a trailing TP can never close the trade below entry. Default 0.5 covers
# roughly 2x crypto round-trip fees plus typical slippage on liquid pairs.
TRAILING_TP_MIN_PROFIT_BUFFER_PCT=0.5
LOG_LEVEL=INFO
LOG_PROFILE=PRODUCTION
LOG_FILE=logs/trading_bot.log
UNIVERSE_LOG_FILE=logs/universe_candidates.log
DB_MARKET_DATA=data/market_data.sqlite
DB_TRADES=data/trades.sqlite
DB_APP=data/app.sqlite
LOCK_FILE=run/trading_scheduler.lock

# --- Web app authentication ----------------------------------------------
# Used only on first boot to seed the initial admin user. Once the row
# exists, these env values are no longer consulted; rotate the password
# from the Settings UI or via a manual DB reset.
ADMIN_USERNAME=mattia
ADMIN_PASSWORD=21Antarte21
ADMIN_DISPLAY_NAME=Administrator

# When the app is served over HTTPS in production, set this to true so the
# session cookie is marked Secure. Behind plain HTTP (dev / Traefik on
# trading.local) leave it false.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# --- CORS ------------------------------------------------------------------
# With the recommended server-side proxy pattern (frontend Route Handlers),
# the backend never receives cross-origin requests so this can stay empty.
# Set it only if you re-expose `api.trading.local` directly to the browser.
CORS_ALLOWED_ORIGINS=
