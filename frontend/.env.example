# URL del backend dal punto di vista del processo Next.js (server-side).
# Con il pattern proxy via Route Handler (raccomandato), il browser non
# parla mai direttamente con il backend: tutte le chiamate passano per
# /api/proxy/* su questo frontend, che rinvia all'URL qui sotto.
#
# In Docker, "backend" è il nome del servizio nella rete trading_internal.
BACKEND_INTERNAL_URL=http://backend:8000
