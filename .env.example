# Copia in .env e compila. Il file .env è in .gitignore: MAI committare chiavi.

TZ=Europe/Rome

# Postgres del progetto
POSTGRES_USER=bot
POSTGRES_DB=etoro_bot
DB_TRADING_PASSWORD=change-me

# Host servito da Traefik (LAN-only: .local; internet: <sub>.longobardo.me)
TRADING_HOST=trading.longobardo.me

# Chiavi eToro e OpenAI: NON vanno qui.
# Sono credenziali personali legate all'identità SSO. Si inseriscono dalla UI,
# in Impostazioni → «Chiavi API personali»: il backend le cifra con AUTH_SECRET
# e le salva su Postgres (tabella user_credentials). Nessuna variabile
# ETORO_API_KEY / ETORO_USER_KEY / OPENAI_API_KEY viene più letta dall'ambiente.

AUTHENTIK_HOST=
AUTH_AUTHENTIK_ID=
AUTH_AUTHENTIK_SECRET=
# Segreto di sessione Auth.js — genera con: openssl rand -base64 32
AUTH_SECRET=

# La stessa entropia di AUTH_SECRET cifra le chiavi personali nel backend.
# Non aggiungere una seconda chiave: Compose la passa come TRADING_CREDENTIALS_SECRET.
