{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/dashboard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Instrument Sans|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Instrument Sans, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:environment|mode|killSwitch|breaker|nextRun|left|right|key|ref|className|style|children)$/]",
        "message": "<AppHeader> doesn't accept that prop. Declared props: environment, mode, killSwitch, breaker, nextRun, left, right."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppHeader'] > JSXAttribute[name.name='environment'] > Literal[value!=/^(?:demo|real)$/]",
        "message": "<AppHeader> environment must be one of 'demo' | 'real'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppHeader'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:dry-run|live)$/]",
        "message": "<AppHeader> mode must be one of 'dry-run' | 'live'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppHeader'] > JSXAttribute[name.name='killSwitch'] > Literal[value!=/^(?:ok|triggered)$/]",
        "message": "<AppHeader> killSwitch must be one of 'ok' | 'triggered'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppHeader'] > JSXAttribute[name.name='breaker'] > Literal[value!=/^(?:ok|triggered)$/]",
        "message": "<AppHeader> breaker must be one of 'ok' | 'triggered'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|action|children|className|style|bodyStyle|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, description, action, children, className, style, bodyStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|description|children|footer|onClose|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, title, description, children, footer, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='DotIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|style|key|ref|className|style|children)$/]",
        "message": "<DotIndicator> doesn't accept that prop. Declared props: status, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DotIndicator'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:ok|triggered)$/]",
        "message": "<DotIndicator> status must be one of 'ok' | 'triggered'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|options|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, options."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<SidebarNavItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|height|style|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: width, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Stamp> doesn't accept that prop. Declared props: tone, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:approved|rejected|neutral|caution|accent|solid-danger|solid-caution)$/]",
        "message": "<Stamp> tone must be one of 'approved' | 'rejected' | 'neutral' | 'caution' | 'accent' | 'solid-danger' | 'solid-caution'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|align|key|ref|className|style|children)$/]",
        "message": "<TableColumn> doesn't accept that prop. Declared props: key, label, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<TableColumn> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|tone|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: title, description, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|success|error)$/]",
        "message": "<Toast> tone must be one of 'neutral' | 'success' | 'error'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
