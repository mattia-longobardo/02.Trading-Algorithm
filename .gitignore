# Python virtual environment and compiled files
.env
.venv
__pycache__/
*.pyc
*.pyo
*.pyd

# Backend runtime data
backend/data/*
backend/logs/*
backend/run/*
!backend/data/.gitkeep
!backend/logs/.gitkeep
!backend/run/.gitkeep

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env
frontend/.env.local
frontend/*.tsbuildinfo

# Editors / OS
.vscode
.idea
.DS_Store

# AI tooling
.claude/
.superpowers/

# Runtime v3
state/*
!state/.gitkeep
# Report generati a runtime (per utente): dati, non sorgenti
reports/*
!reports/.gitkeep
data/
backend/.venv/
backend/*.egg-info/
backend/.pytest_cache/
backend/.ruff_cache/
